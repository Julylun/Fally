# YOLO weights (relative to process cwd, usually edge_server/)
MODEL_PATH=../Resources/best.pt

# Webcam index (see cv2.VideoCapture)
CAMERA_INDEX=0

# Detection (matches Resources/fally_cctv.py conf=0.40)
CONFIDENCE_THRESHOLD=0.4
FALL_LABEL=Fall Detected
FALL_COOLDOWN_SECONDS=3.0
INFERENCE_EVERY_N_FRAMES=2

# Edge identity & backend sync
CAMERA_ID=cam-edge-01
BACKEND_URL=http://localhost:3000
BACKEND_SHARED_TOKEN=devtoken

# Local persistence (relative paths recommended for Docker volumes later)
LOCAL_DB_PATH=./data/edge.db
LOCAL_SNAPSHOT_DIR=./data/snapshots

# HTTP server
PORT=8001

# Path to Edge UI (relative to cwd when starting uvicorn from edge_server/)
UI_INDEX_PATH=./ui/index.html
